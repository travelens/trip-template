{
  "name": "trip-template",
  "author": "Chris Tham (chris@christham.net)",
  "description": "Trip template for travelens",
  "license": "MIT",
  "version": "2.3.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "clean": "rm -rf node_modules .astro dist",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "pnpm run lint:prettier ; pnpm run lint:eslint",
    "lint:prettier": "prettier --write .",
    "lint:eslint": "eslint --fix .",
    "astro": "astro",
    "copydocs": "cp dist/documents.json ../travelens.github.io/src/data/${npm_package_name}.json",
    "refresh": "pnpm dlx @astrojs/upgrade; pnpm up -L"
  },
  "dependencies": {
    "@astrojs/markdoc": "^1.0.6",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@iconify-json/flag": "^1.2.12",
    "@iconify-json/logos": "^1.2.11",
    "@unocss/astro": "^66.7.0",
    "astro": "^6.4.2",
    "astro-seo": "^1.1.0",
    "exifr": "^7.1.3",
    "flexsearch": "^0.8.212",
    "leaflet": "^1.9.4",
    "photoswipe": "^5.4.4",
    "photoswipe-dynamic-caption-plugin": "^1.2.7",
    "schema-dts": "^2.0.0",
    "sharp": "^0.34.5",
    "unocss": "66.7.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/markdown": "^8.0.2",
    "@types/leaflet": "^1.9.21",
    "@typescript-eslint/parser": "^8.60.0",
    "@unocss/eslint-config": "66.7.0",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
