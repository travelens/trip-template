---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import { Image } from 'astro:assets'
import Map from '../common/Map.astro'
import Post from '../common/Post.astro'
import Gallery from '../common/Gallery.astro'
import TripImage from '../trip/trip.jpeg'

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const posts = await getCollection('post', ({ data }) => {
    return data.draft !== true
  })
  return posts
    .sort((a, b) => +a.data.date - +b.data.date)
    .map((post, i) => ({
      params: { id: post.id },
      props: {
        post,
        prev: i > 0 ? posts[i - 1] : undefined,
        next: i < posts.length - 1 ? posts[i + 1] : undefined
      }
    }))
}

// 2. When it's time to render, you can get the entry directly from the prop
export interface Props {
  post: CollectionEntry<'post'>
  prev?: CollectionEntry<'post'>
  next?: CollectionEntry<'post'>
}
const { post, prev, next } = Astro.props
const { Content } = await render(post)
---

<Post post={post}>
  <div class="mx-auto mb-6 px-12 pb-6 bg-white max-w-4xl relative z-10 lg:px-24">
    <div class="pt-6 prose prose-sm sm:prose lg:prose-lg">
      <Content />
    </div>
  </div>
  {post.data.gallery && <Gallery folder={post.data.gallery} />}
  {
    post.data.map && (
      <Map
        text={post.data.location}
        lat={post.data.map[0]}
        lng={post.data.map[1]}
        zoom={post.data.map[2]}
      />
    )
  }
  <div class="giscus mx-auto max-w-4xl"></div>
  <div class="py-12 bg-neutral-200 grid grid-cols-1 md:grid-cols-3">
    {
      prev ? (
        <a
          href={`${import.meta.env.BASE_URL}` + prev.id}
          class="text-white tracking-widest font-heading bg-black flex h-72 block uppercase items-center justify-center relative hover:opacity-75"
        >
          <div class="relative z-10">Previous: {prev.data.title}</div>
          <Image
            src={prev.data.image}
            width={1024}
            class="opacity-50 h-full w-full inset-0 absolute object-cover"
            alt={prev.data.title}
          />
        </a>
      ) : (
        <div />
      )
    }
    <a
      href={`${import.meta.env.BASE_URL}`}
      class="text-white tracking-widest font-heading bg-black flex h-72 block uppercase items-center justify-center relative hover:opacity-75"
    >
      <div class="relative z-10">Back to Trip: {post.data.trip}</div>
      <Image
        src={TripImage}
        width={1024}
        class="opacity-50 h-full w-full inset-0 absolute object-cover"
        alt={post.data.trip}
      />
    </a>
    {
      next ? (
        <a
          href={`${import.meta.env.BASE_URL}` + next.id}
          class="text-white tracking-widest font-heading bg-black flex h-72 block uppercase items-center justify-center relative hover:opacity-75"
        >
          <div class="relative z-10">Next: {next.data.title}</div>
          <Image
            src={next.data.image}
            width={1024}
            class="opacity-50 h-full w-full inset-0 absolute object-cover"
            alt={next.data.title}
          />
        </a>
      ) : (
        <div />
      )
    }
  </div>
  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo="travelens/Discussions"
    data-repo-id="R_kgDOJKp7SA"
    data-category="General"
    data-category-id="DIC_kwDOJKp7SM4CU7c2"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="bottom"
    data-theme="light"
    data-lang="en"
    crossorigin="anonymous"
    async></script>
</Post>
